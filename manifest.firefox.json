{
    "name": "Confluence",
    "description": "Browser Extension for Confluence",
    "short_name": "confluence",
    "author": "Thierry Dalon",
    "browser_specific_settings": {
        "gecko": {
            "id": "confluence-crx@tdalon.github.io",
            "data_collection_permissions": {
                "builtin_data": false,
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "https://*.atlassian.net/wiki/",
        "<all_urls>",
        "storage",
        "contextMenus",
        "activeTab",
        "notifications",
        "clipboardWrite"
    ],
    "version": "2.3",
    "manifest_version": 2,
    "background": {
        "scripts": ["dist/background.bundle.js"],
        "persistent": false
    },
    "browser_action": {
        "default_icon": {
            "128": "images/icon-128.png",
            "16": "images/icon-16.png",
            "32": "images/icon-32.png",
            "48": "images/icon-48.png"
        },
        "default_popup": "dist/search.html#popup"
    },
    "commands": {
        "open_search": {
            "description": "Open Confluence Quick Search (New Tab)",
            "suggested_key": {
                "default": "Alt+S"
            }
        },
        "copy_link": {
            "description": "Copy Nice Page Link",
            "suggested_key": {
                "default": "Ctrl+Shift+C"
            }
        },
        "copy_breadcrumb_link": {
            "description": "Copy Breadcrumb Link"
        },
        "toc_toggle": {
            "suggested_key": {
                "default": "Ctrl+Shift+T"
            },
            "description": "Toggle Table of Contents"
        },
        "quick_insert_snippet": {
            "description": "Show Snippet Selector",
            "suggested_key": {
                "default": "Alt+I"
            }
        }
    },
    "icons": {
        "128": "images/icon-128.png",
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-48.png"
    },
    "omnibox": {
        "keyword": "cf"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["snippet-injector.js"],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        "snippet-injector.js",
        "dist/search.bundle.js",
        "dist/snippets-ui.bundle.js",
        "dist/label-dictionary-ui.bundle.js",
        "toc-content.js",
        "toc-overlay.css"
    ]
}
